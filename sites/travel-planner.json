{
  "name": "Travel Planner",
  "url": "http://sanfacheng.cyou/travel/",
  "expectedStatusCode": 200,
  "viewport": {
    "width": 1920,
    "height": 1080
  },
  "screenshots": [
    "fullpage"
  ],
  "checks": [
    "screenshot",
    "console",
    "performance"
  ],
  "timeout": 15000,
  "customChecks": [
    {
      "name": "Page loads correctly",
      "type": "element",
      "selector": "body"
    },
    {
      "name": "No undefined text",
      "type": "custom",
      "script": "return !document.body.innerText.includes('undefined')"
    },
    {
      "name": "Has input or form elements",
      "type": "custom",
      "script": "return document.querySelectorAll('input, textarea, select, button').length > 0"
    },
    {
      "name": "No console errors",
      "type": "custom",
      "script": "return true"
    }
  ]
}
