{
  "name": "Portal Page",
  "url": "http://sanfacheng.cyou/",
  "expectedStatusCode": 200,
  "viewport": {
    "width": 1920,
    "height": 1080
  },
  "screenshots": [
    "fullpage"
  ],
  "checks": [
    "screenshot",
    "console",
    "performance"
  ],
  "timeout": 15000,
  "customChecks": [
    {
      "name": "Page loads correctly",
      "type": "element",
      "selector": "body"
    },
    {
      "name": "No undefined text",
      "type": "custom",
      "script": "return !document.body.innerText.includes('undefined')"
    },
    {
      "name": "System info visible",
      "type": "custom",
      "script": "return document.body.innerText.length > 100"
    },
    {
      "name": "Has links",
      "type": "custom",
      "script": "return document.querySelectorAll('a').length >= 1"
    },
    {
      "name": "No console errors",
      "type": "custom",
      "script": "return true"
    }
  ]
}
