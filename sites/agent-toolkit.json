{
  "name": "Agent Toolkit",
  "url": "http://sanfacheng.cyou/agent-toolkit/",
  "expectedStatusCode": 200,
  "viewport": {
    "width": 1920,
    "height": 1080
  },
  "screenshots": [
    "fullpage"
  ],
  "checks": [
    "screenshot",
    "console",
    "performance"
  ],
  "timeout": 15000,
  "customChecks": [
    {
      "name": "Page loads correctly",
      "type": "element",
      "selector": "body"
    },
    {
      "name": "No undefined text",
      "type": "custom",
      "script": "return !document.body.innerText.includes('undefined')"
    },
    {
      "name": "Agent cards rendered",
      "type": "custom",
      "script": "return document.querySelectorAll('.agent-card, [class*=\"agent\"]').length > 0 || document.querySelectorAll('canvas').length > 0"
    },
    {
      "name": "Has login form or agent list",
      "type": "custom",
      "script": "return document.querySelectorAll('input').length > 0 || document.querySelectorAll('.agent-card').length > 0 || document.body.innerText.length > 500"
    },
    {
      "name": "No console errors",
      "type": "custom",
      "script": "return true"
    }
  ]
}
