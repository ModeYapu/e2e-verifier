{
  "name": "LogMonitor",
  "sites": [
    {
      "name": "Login Page",
      "url": "http://sanfacheng.cyou/logmon/login",
      "expectedStatusCode": 200,
      "viewport": {
        "width": 1920,
        "height": 1080
      },
      "screenshots": [
        "fullpage"
      ],
      "checks": [
        "screenshot",
        "console",
        "performance"
      ],
      "timeout": 15000,
      "customChecks": [
        {
          "name": "Login form visible",
          "type": "element",
          "selector": ".el-form"
        },
        {
          "name": "Username input",
          "type": "element",
          "selector": ".el-form input:not([type='password'])"
        },
        {
          "name": "Password input",
          "type": "element",
          "selector": ".el-form input[type='password']"
        },
        {
          "name": "Login button",
          "type": "javascript",
          "script": "!!document.querySelector('.el-form button') && /登录|login/i.test(document.querySelector('.el-form button').textContent)"
        }
      ]
    },
    {
      "name": "Overview Dashboard",
      "url": "http://sanfacheng.cyou/logmon/",
      "expectedStatusCode": 200,
      "viewport": {
        "width": 1920,
        "height": 1080
      },
      "screenshots": [
        "fullpage"
      ],
      "checks": [
        "screenshot",
        "console",
        "performance"
      ],
      "timeout": 20000,
      "customChecks": [
        {
          "name": "SPA shell loaded",
          "type": "custom",
          "script": "return document.querySelectorAll(\"script[src]\").length > 0"
        },
        {
          "name": "No undefined text",
          "type": "custom",
          "script": "return !document.body.innerText.includes(\"undefined\")"
        },
        {
          "name": "No NaN text",
          "type": "custom",
          "script": "return !document.body.innerText.includes(\"NaN\")"
        }
      ]
    },
